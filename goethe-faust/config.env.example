# Directory containing the downloaded .nq file (mounted read-only as /input)
NQ_INPUT_DIR=/path/to/dir/containing/nq-file

# QLever index directory (created on first run)
INDEX_DIR=/path/to/qlever-index

# Service ports
QLEVER_PORT=2343
SHMARQL_PORT=2342
MCPO_PORT=2344

# QLever memory limit
QLEVER_MEMORY=4GB
